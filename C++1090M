#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, k, c, m=0; cin >> n >> k;
    int left=0, last=-1;
    for (int i=0; i<n; i++){
      cin >> c;
      if (c==last)
        left=i;
      last=c;
      m=max(m, i-left+1);
    }
    cout << m;
}
